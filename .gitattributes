# Auto normalize line endings
* text=auto

# C++ source files
*.cpp text diff=cpp
*.h text diff=cpp
*.hpp text diff=cpp

# CMake files
CMakeLists.txt text
*.cmake text

# Scripts
*.bat text eol=crlf
*.ps1 text eol=crlf

# JSON files
*.json text

# Markdown
*.md text

# Binary files
*.exe binary
*.dll binary
*.lib binary
*.obj binary
*.pdb binary
*.ilk binary
*.db binary
