{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\build\\${input:buildConfig}\\bin\\MSFS-Flight-Data-Recorder.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "console": "integratedTerminal",
      "preLaunchTask": "CMake: Build"
    }
  ],
  "inputs": [
    {
      "id": "buildConfig",
      "type": "pickString",
      "description": "Select configuration to launch",
      "options": [
        "Debug",
        "Release"
      ],
      "default": "Debug"
    }
  ]
}
